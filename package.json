{
  "name": "snap-squad",
  "version": "0.6.0",
  "description": "Get started with Squad faster — ready-made squad presets for instant deployment",
  "type": "module",
  "bin": {
    "snap-squad": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src/registry/presets"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "squad",
    "copilot",
    "multi-agent",
    "warm-start",
    "mcp"
  ],
  "author": "paulyuk",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/paulyuk/snap-squad.git"
  },
  "homepage": "https://github.com/paulyuk/snap-squad#readme",
  "bugs": {
    "url": "https://github.com/paulyuk/snap-squad/issues"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "yaml": "^2.7.0",
    "chalk": "^5.4.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  }
}
